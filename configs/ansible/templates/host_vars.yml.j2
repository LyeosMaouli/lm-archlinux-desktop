---
# Host-specific variables for ${HOSTNAME:-localhost}
# This file is automatically generated from deploy-config/deploy.conf
# DO NOT EDIT MANUALLY - Changes will be overwritten

# Hardware specific configuration
hardware:
  type: ${HARDWARE_TYPE:-laptop}
  cpu_vendor: ${CPU_VENDOR:-intel}
  gpu_vendor: ${GPU_VENDOR:-intel}
  form_factor: ${FORM_FACTOR:-laptop}
  
# Network configuration
network:
  hostname: ${HOSTNAME:-localhost}
  interfaces:
    - name: wlan0
      type: wireless
    - name: eth0
      type: ethernet
      
# Storage configuration
storage:
  filesystem: ${FILESYSTEM:-ext4}
  encryption: ${ENCRYPTION_ENABLED:-true}
  swap:
    type: hybrid  # zram + hibernation swapfile
    zram_size: 4G
    swapfile_size: 8G
    
# Display configuration
display:
  primary:
    resolution: "${DISPLAY_RESOLUTION:-1920x1080}"
    refresh_rate: ${DISPLAY_REFRESH_RATE:-60}
    
# Power management
power_management:
  battery_optimization: ${BATTERY_OPTIMIZATION:-true}
  cpu_scaling_governor: ${CPU_SCALING_GOVERNOR:-powersave}
  intel_pstate: ${INTEL_PSTATE:-true}
  wifi_power_save: ${WIFI_POWER_SAVE:-true}
  
# Bluetooth
bluetooth:
  enabled: ${ENABLE_BLUETOOTH:-true}
  auto_power_on: ${BLUETOOTH_AUTO_POWER:-true}
  
# Audio
audio:
  system: ${AUDIO_SYSTEM:-pipewire}
  bluetooth_codec: ${BLUETOOTH_CODEC:-aptx}
  
# Development tools (profile dependent)
development:
  languages:
    - python
    - nodejs
    - rust
    - go
  editors:
    - visual-studio-code-bin
  tools:
    - docker
    - kubectl
    - terraform
    
# Security enhancements
security_enhanced:
  disk_encryption: ${ENCRYPTION_ENABLED:-true}
  secure_boot: ${SECURE_BOOT:-false}  # May conflict with Hyprland
  tpm2: ${ENABLE_TPM2:-true}
  firewall_strict: ${FIREWALL_STRICT:-true}

# Git configuration (from deploy.conf)
git:
  username: "${GIT_USERNAME:-Your Name}"
  email: "${GIT_EMAIL:-user@example.com}"
  
# SSH configuration
ssh:
  generate_keys: ${GENERATE_SSH_KEYS:-true}
  key_type: "${SSH_KEY_TYPE:-ed25519}"