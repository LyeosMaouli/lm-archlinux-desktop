---
# Ansible Inventory Configuration
# This file is automatically generated from config/deploy.conf
# DO NOT EDIT MANUALLY - Changes will be overwritten

all:
  hosts:
    ${HOSTNAME:-localhost}:
      ansible_host: 127.0.0.1
      ansible_connection: local
      ansible_user: root
      ansible_become: yes

  children:
    laptops:
      hosts:
        ${HOSTNAME:-localhost}:

    desktops:
      hosts: {}

  vars:
    # Global variables
    ansible_python_interpreter: /usr/bin/python3

    # Project configuration
    project_name: lm-archlinux-desktop
    deployment_user: "${USER_NAME:-user}"

    # System configuration
    locale: "${LOCALE:-en_US.UTF-8}"
    keymap: "${KEYMAP:-us}"
    timezone: "${TIMEZONE:-UTC}"
    hostname: "${HOSTNAME:-localhost}"

    # Package mirrors
    country_code: "${COUNTRY_CODE:-}"
    mirror_country: "${MIRROR_COUNTRY:-}"

    # Desktop environment
    desktop_environment: ${DESKTOP_SESSION:-hyprland}
    display_manager: ${DISPLAY_MANAGER:-sddm}
    desktop_theme: "${DESKTOP_THEME:-catppuccin-mocha}"

    # Security settings
    enable_firewall: ${ENABLE_FIREWALL:-true}
    enable_fail2ban: ${ENABLE_FAIL2BAN:-true}
    enable_audit: ${ENABLE_AUDIT:-true}
    
    # SSH configuration
    ssh_port: ${SSH_PORT:-22}
    enable_ssh: ${ENABLE_SSH:-false}

    # Power management
    enable_tlp: ${ENABLE_TLP:-true}
    enable_thermald: ${ENABLE_THERMALD:-true}
    
    # Hardware acceleration
    enable_hardware_accel: ${ENABLE_HARDWARE_ACCEL:-true}
    
    # Additional features
    enable_bluetooth: ${ENABLE_BLUETOOTH:-true}
    enable_printing: ${ENABLE_PRINTING:-true}
    enable_swap: ${ENABLE_SWAP:-true}
    
    # Package management
    enable_aur: ${ENABLE_AUR:-true}
    parallel_downloads: ${PARALLEL_DOWNLOADS:-5}
    custom_packages: "${CUSTOM_PACKAGES:-}"