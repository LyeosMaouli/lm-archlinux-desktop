---
# Global variables for all hosts
# This file is automatically generated from config/deploy.conf
# DO NOT EDIT MANUALLY - Changes will be overwritten

# System configuration
system:
  locale: "${LOCALE:-en_US.UTF-8}"
  keymap: "${KEYMAP:-us}"
  timezone: "${TIMEZONE:-UTC}"
  hostname: "${HOSTNAME:-localhost}"
  
# User configuration
users:
  main_user: "${USER_NAME:-user}"
  groups:
    - wheel
    - audio
    - video
    - storage
    - network
    - input
    - optical
  shell: /bin/zsh

# Package management
packages:
  base_packages:
    - base-devel
    - linux-firmware
    - networkmanager
    - sudo
    - openssh
    - git
    - reflector
    - neovim
    - tmux
    - htop
    - zsh
    - curl
    - wget
    - tree
    - zip
    - unzip
    - trash-cli
    
  aur_packages:
    - visual-studio-code-bin
    - discord
    - zoom
    - hyprpaper
    - bibata-cursor-theme
    
# Desktop environment
desktop:
  environment: ${DESKTOP_SESSION:-hyprland}
  display_manager: ${DISPLAY_MANAGER:-sddm}
  theme: "${DESKTOP_THEME:-catppuccin-mocha}"
  
  hyprland_packages:
    - hyprland
    - waybar
    - wofi
    - mako
    - kitty
    - thunar
    - grim
    - slurp
    - wl-clipboard
    - xdg-desktop-portal-hyprland
    - polkit-gnome
    - qt5-wayland
    - qt6-wayland
    
  graphics_packages:
    - mesa
    - intel-media-driver
    - vulkan-intel
    
  audio_packages:
    - pipewire
    - pipewire-pulse
    - pipewire-alsa
    - wireplumber
    
  applications:
    - firefox
    - thunderbird
    - libreoffice-still
    - vlc
    - okular
    - cups
    
# Security configuration
security:
  firewall:
    enabled: ${ENABLE_FIREWALL:-true}
    default_policy: deny
    
  fail2ban:
    enabled: ${ENABLE_FAIL2BAN:-true}
    
  audit:
    enabled: ${ENABLE_AUDIT:-true}
    
  ssh:
    port: ${SSH_PORT:-22}
    permit_root_login: "no"
    password_authentication: "no"
    pubkey_authentication: "yes"
    
# Power management
power:
  tlp:
    enabled: ${ENABLE_TLP:-true}
    
  thermald:
    enabled: ${ENABLE_THERMALD:-true}
    
# Mirrors
mirrors:
  country: "${MIRROR_COUNTRY:-}"
  
# Bootloader
bootloader:
  type: ${BOOTLOADER:-systemd-boot}
  timeout: 5
  
# Logging
logging:
  directory: /var/log/ansible
  max_size: 100M
  backup_count: 5

# Profile-specific configurations
profile:
  name: "${PROFILE:-personal}"
  enable_development: ${ENABLE_DEVELOPMENT:-false}
  enable_gaming: ${ENABLE_GAMING:-false}
  custom_packages: "${CUSTOM_PACKAGES:-}"